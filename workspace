#include <iostream>
#include <fstream>
#include <cstdint>
#include <vector>
using namespace std;

class BitWriter {
private:
    ofstream &file;
    uint8_t temp;
    int c;

public:
    BitWriter(ofstream &f) : file(f), temp(0), c(0){}
    void WriteBitSequence(uint32_t data, int length){
        for (int i = length - 1; i >= 0; i--){
            int bit = (data >> i) & 1;
            temp = (temp << 1) | bit;
            c++;

            if (c == 8){
                file.put(temp);
                temp = 0;
                c = 0;
            }
        }
    }
    void Padding(){
        if (c > 0){
            temp <<= (8 - c);
            file.put(temp);
            temp = 0;
            c = 0;
        }
    }
    ~BitWriter(){
        Padding();
        file.close();
    }
};

class BitReader {
private:
    ifstream &file;
    uint8_t temp;
    int c;

public:
    BitReader(ifstream &f) : file(f), temp(0), c(0){}

    uint32_t ReadBitSequence(int length){
        uint32_t result = 0;

        for (int i = 0; i < length; i++){
            if (c == 0){
                int byte = file.get();
                temp = static_cast<uint8_t>(byte);
                c = 8;
            }

            int bit = (temp >> 7) & 1;
            temp <<= 1;
            c--;
            result = (result << 1) | bit;
        }

        return result;
    }

    ~BitReader(){
        file.close();
    }
};


