#include <iostream>
#include <fstream>
#include <cstdint>
#include <vector>
#include <random>
using namespace std;

class BitWriter {
private:
    ofstream &file;
    uint8_t temp;
    int c;

public:
    BitWriter(ofstream &f) : file(f), temp(0), c(0){}
    void WriteBitSequence(uint32_t data, int length){
        for (int i = length - 1; i >= 0; i--){
            int bit = (data >> i) & 1;
            temp = (temp << 1) | bit;
            c++;

            if (c == 8){
                file.put(temp);
                temp = 0;
                c = 0;
            }
        }
    }
    void Padding(){
        if (c > 0){
            temp <<= (8 - c);
            file.put(temp);
            temp = 0;
            c = 0;
        }
    }
    ~BitWriter(){
        Padding();
        file.close();
    }
};

class BitReader {
private:
    ifstream &file;
    uint8_t temp;
    int c;

public:
    BitReader(ifstream &f) : file(f), temp(0), c(0){}

    uint32_t ReadBitSequence(int length){
        uint32_t result = 0;

        for (int i = 0; i < length; i++){
            if (c == 0){
                int byte = file.get();
                temp = static_cast<uint8_t>(byte);
                c = 8;
            }

            int bit = (temp >> 7) & 1;
            temp <<= 1;
            c--;
            result = (result << 1) | bit;
        }

        return result;
    }

    ~BitReader(){
        file.close();
    }
};

class Vector_Operation{

public:
    uint64_t limb[2];

    Vector_Operation(){
        fill(limb, limb+2, 0);
    }

    static constexpr uint8_t Polynomial[2] = {
        0b01100011,
        0b00000001
    };

    void Random() {
        random_device rd;
        mt19937_64 gen(rd());
        limb[0] = gen();
        limb[1] = gen() & Polynomial[1];
    }

    // Тестові вектори
    uint64_t Test_Keys[10] = {
        0x0000000000000000, 0x000000000000000,
        0x0010203040506070, 0x8090a0b0c0d0e0f,
        0x123456789abcdef0, 0x123456789abcdef,
        0x0010203040506070, 0x8090a0b0c0d0e0f,
        0x123456789abcdeff, 0xedcba9876543210
    };

    uint64_t Test_Plaintexts[10] = {
        0x0010203040506070, 0x8090a0b0c0d0e0f,
        0x0000000000000000, 0x000000000000000,
        0x123456789abcdef0, 0x123456789abcdef,
        0x0010203040506070, 0x8090a0b0c0d0e0f,
        0x123456789abcdeff, 0xedcba9876543210
    };

    void reduce(uint8_t t[8]) const {
        for (int i = 7; i >= 0; i--) {
            uint8_t w = t[i];
            t[i] = 0;

            while (w) {
                int b = __builtin_ctzll(w);
                int k = i*8 + b;
                if (k < 8) {
                    t[k >> 3] |= 1ULL << (k & 7);
                    w &= w - 1;
                    continue;
                }

                int d = k - 8;
                t[ d >> 3 ]   ^= 1ULL << ( d & 7 );
                t[(d+1)>>3]   ^= 1ULL << ((d+1)&7);
                t[(d+5)>>3]   ^= 1ULL << ((d+5)&7);
                t[(d+6)>>3]   ^= 1ULL << ((d+6)&7);

                w &= w - 1;
            }
        }
        t[1] &= Polynomial[1];
    }

    void Reduce(){
        limb[1] &= Polynomial[1];
    }

    Vector_Operation XOR(const Vector_Operation& v) const {
        Vector_Operation r;
        r.limb[0] = limb[0] ^ v.limb[0];
        r.limb[1] = limb[1] ^ v.limb[1];
        r.Reduce();
        return r;
    }

    // константи KC_i
    vector<uint32_t> KC_i = {
        0x9e3779b9, 0x3779b99e,
        0x3c6ef373, 0x6ef3733c,
        0x78dde6e6, 0xdde6e678,
        0xf1bbcdcc, 0xbbcdccf1,
        0xe3779b99, 0x779b99e3,
        0xc6ef3733, 0xef3733c6,
        0x8dde6e67, 0xde6e678d,
        0x1bbcdccf, 0xbcdccf1b
    };

    uint32_t G_function(uint8_t X_1, uint8_t X_2, uint8_t X_3, uint8_t X_4){
        uint32_t Output;



        return Output;
    }

    string Print() const {
        static const char* hex = "0123456789ABCDEF";
        string s;
        s.reserve(64);

        for (int i = 1; i >= 0; i--) {
            uint64_t v = limb[i];
            for (int j = 60; j >= 0; j -= 4) s.push_back(hex[(v >> j) & 15]);
        }

        int p = 0;
        while (p+1 < (int)s.size() && s[p] == '0') p++;
        cout << s.substr(p) << "\n";
        return s.substr(p);
    }

};

int main()
{

    Vector_Operation v1, v2, v3;

    v1.Random(); v2.Random();
    v1.Print(); v2.Print();

    v3 = v1.XOR(v2);

    v3.Print();
    



    return 0;
}


