#include <iostream>
#include <fstream>
#include <cstdint>
#include <vector>
#include <random>
#include <cmath>
using namespace std;

class BitWriter {
private:
    ofstream &file;
    uint8_t temp;
    int c;

public:
    BitWriter(ofstream &f) : file(f), temp(0), c(0){}
    void WriteBitSequence(uint32_t data, int length){
        for (int i = length - 1; i >= 0; i--){
            int bit = (data >> i) & 1;
            temp = (temp << 1) | bit;
            c++;

            if (c == 8){
                file.put(temp);
                temp = 0;
                c = 0;
            }
        }
    }
    void Padding(){
        if (c > 0){
            temp <<= (8 - c);
            file.put(temp);
            temp = 0;
            c = 0;
        }
    }
    ~BitWriter(){
        Padding();
        file.close();
    }
};

class BitReader {
private:
    ifstream &file;
    uint8_t temp;
    int c;

public:
    BitReader(ifstream &f) : file(f), temp(0), c(0){}

    uint32_t ReadBitSequence(int length){
        uint32_t result = 0;

        for (int i = 0; i < length; i++){
            if (c == 0){
                int byte = file.get();
                temp = static_cast<uint8_t>(byte);
                c = 8;
            }

            int bit = (temp >> 7) & 1;
            temp <<= 1;
            c--;
            result = (result << 1) | bit;
        }

        return result;
    }

    ~BitReader(){
        file.close();
    }
};

class Vector_Operation{

public:
    uint64_t limb[2];

    Vector_Operation(){
        fill(limb, limb+2, 0);
    }

    static constexpr uint8_t Polynomial[2] = {
        0b01100011,
        0b00000001
    };

    void Random() {
        random_device rd;
        mt19937_64 gen(rd());
        limb[0] = gen();
        limb[1] = gen() & Polynomial[1];
    }

    Vector_Operation XOR(const Vector_Operation& v) const {
        Vector_Operation r;
        r.limb[0] = limb[0] ^ v.limb[0];
        r.limb[1] = limb[1] ^ v.limb[1];
        return r;
    }

    // Тестові вектори
    uint64_t Test_Keys[10] = {
        0x0000000000000000, 0x000000000000000,
        0x0010203040506070, 0x8090a0b0c0d0e0f,
        0x123456789abcdef0, 0x123456789abcdef,
        0x0010203040506070, 0x8090a0b0c0d0e0f,
        0x123456789abcdeff, 0xedcba9876543210
    };

    uint64_t Test_Plaintexts[10] = {
        0x0010203040506070, 0x8090a0b0c0d0e0f,
        0x0000000000000000, 0x000000000000000,
        0x123456789abcdef0, 0x123456789abcdef,
        0x0010203040506070, 0x8090a0b0c0d0e0f,
        0x123456789abcdeff, 0xedcba9876543210
    };

    void reduce(uint8_t t[8]) const {
        for (int i = 7; i >= 0; i--) {
            uint8_t w = t[i];
            t[i] = 0;

            while (w) {
                int b = __builtin_ctzll(w);
                int k = i*8 + b;
                if (k < 8) {
                    t[k >> 3] |= 1ULL << (k & 7);
                    w &= w - 1;
                    continue;
                }

                int d = k - 8;
                t[ d >> 3 ]   ^= 1ULL << ( d & 7 );
                t[(d+1)>>3]   ^= 1ULL << ((d+1)&7);
                t[(d+5)>>3]   ^= 1ULL << ((d+5)&7);
                t[(d+6)>>3]   ^= 1ULL << ((d+6)&7);

                w &= w - 1;
            }
        }
        t[1] &= Polynomial[1];
    }

    void Reduce(){
        limb[1] &= Polynomial[1];
    }

    // G function
