    string Print() const {
        static const char* hex = "0123456789ABCDEF";
        string s;
        s.reserve(64);

        for (int i = 1; i >= 0; i--) {
            uint64_t v = limb[i];
            for (int j = 60; j >= 0; j -= 4) s.push_back(hex[(v >> j) & 15]);
        }

        int p = 0;
        while (p+1 < (int)s.size() && s[p] == '0') p++;
        cout << s.substr(p) << "\n";
        return s.substr(p);
    }

